{
  "name": "fuzo-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --open",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "seed:masterbots": "node --loader ts-node/esm ./scripts/seedMasterBots.ts",
    "test:mcp": "node --loader ts-node/esm ./scripts/testMCPSeeding.ts",
    "test:mcp:powershell": "powershell -ExecutionPolicy Bypass -File ./scripts/test-mcp.ps1",
    "setup:env": "node ./scripts/setup-env.js",
    "mcp:supabase": "node ./scripts/test-supabase-mcp.js",
    "test:feed": "node ./scripts/test-feed-connection.js",
    "test:restaurants": "node ./scripts/test-restaurant-matching.js",
    "seed:bot-posts": "node ./scripts/seedBotPosts.js",
    "test:bot-posts": "node ./scripts/test-bot-posts.js",
    "seed:recipes": "node --loader ts-node/esm ./scripts/populate-recipes.ts",
    "seed:openai-prompts": "node --loader ts-node/esm ./scripts/seed-openai-prompts.ts",
    "test:daily-plan": "npx tsx scripts/test-daily-plan.ts",
    "setup:phase2": "npm run seed:openai-prompts && npm run seed:recipes"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.1.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.57.4",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "dotenv": "^16.6.1",
    "framer-motion": "^11.0.0",
    "hono": "^4.9.7",
    "lucide-react": "^0.400.0",
    "maplibre-gl": "^4.0.0",
    "motion": "^10.16.0",
    "openai": "^5.20.3",
    "react": "^18.2.0",
    "react-dnd": "^16.0.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "7.55.0",
    "react-map-gl": "^7.1.0",
    "react-responsive-masonry": "^2.1.0",
    "react-slick": "^0.30.0",
    "recharts": "^2.8.0",
    "sonner": "2.0.3",
    "tailwind-merge": "^2.0.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-alpha.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-slick": "^0.23.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jsdom": "^27.0.0",
    "tailwindcss": "^4.0.0-alpha.0",
    "typescript": "^5.9.2",
    "vite": "^5.2.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
