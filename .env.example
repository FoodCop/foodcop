# ==========================================
# PUBLIC VARIABLES (Vercel & Local)
# These are safe to expose to the browser
# ==========================================

# Supabase Connection
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url_here"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"


# ==========================================
# SECRET VARIABLES (Vercel & Local)
# Backend only. NEVER prefix with NEXT_PUBLIC_
# ==========================================

# AI Services
GEMINI_API_KEY="your_gemini_api_key_here"

# External APIs
YOUTUBE_API_KEY="your_youtube_api_key_here"

# Social Integrations (Optional)
VITE_META_APP_TOKEN="your_meta_app_token_here"


# ==========================================
# SUPABASE SECRETS 
# These go into the Supabase Dashboard -> Edge Functions Secrets
# Do NOT put these in Vercel.
# ==========================================

# GOOGLE_CLIENT_ID="your_google_client_id_here"
# GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
# GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"
# YOUTUBE_API_KEY="your_youtube_api_key_here"
# GEMINI_API_KEY="your_gemini_api_key_here"
